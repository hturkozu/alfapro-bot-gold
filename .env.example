# ===========================================
# AlfaPro Bot — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyala ve doldur.
# .env dosyası ASLA git'e girmez.
# ===========================================

# --- Zorunlu ---
# Fernet master key — `python scripts/generate_master_key.py` ile üret
ALFAPRO_MASTER_KEY=

# --- Uygulama ---
APP_ENV=development                 # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# --- Veritabanı ---
DATABASE_URL=sqlite:///./data/alfapro.db

# --- Log ---
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
LOG_DIR=./logs

# --- Bitget (opsiyonel, panelden de girilebilir) ---
# Bunları .env'e koyarsan ilk kurulumda otomatik yüklenir.
# Panel üzerinden girmeyi tercih edersen boş bırak.
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=
BITGET_SANDBOX=false                 # Bitget'te ayrı demo/testnet yoksa false

# --- AI (Faz 4) ---
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Paper trading komisyonu ---
# Bitget USDT-M default taker = %0.06. Paper PnL bu yüzdeden açılış+kapanış fee'siyle düşülür.
PAPER_TAKER_FEE_PCT=0.06

# --- Paper trading: break-even & trailing stop ---
# 0 → kapalı. Tipik kullanım:
#   PAPER_BREAKEVEN_TRIGGER_PCT=50  → fiyat TP mesafesinin yarısına gelince SL entry'ye taşınır
#   PAPER_BREAKEVEN_OFFSET_PCT=0.06 → BE'ye taşırken entry üstü/altı %0.06 tampon (fee'yi karşılar)
#   PAPER_TRAILING_PCT=0.4          → fiyat lehte hareket ettikçe SL %0.4 aralıkta peki kovalar
PAPER_BREAKEVEN_TRIGGER_PCT=0
PAPER_BREAKEVEN_OFFSET_PCT=0.06
PAPER_TRAILING_PCT=0

# --- Telegram (Faz 4, opsiyonel) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
